@{
    ViewData["Title"] = "Listado de Empleados";
}

<h2 class=" mt-4">Gestion de Nominas</h2>

<form asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <input type="text" name="busqueda" value="@ViewBag.Busqueda" class="form-control" placeholder="Nombre o Depto...">
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Registrar Nuevo Empleado</a>
</div>

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Nombre Completo</th>
            <th>Departamento</th>
            <th>Salario</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NombreCompleto</td>
                <td>@item.Departamento</td>
                <td>@item.Salario.ToString("C0")</td>
                <td>
                    <span class="badge @(item.Activo ? "bg-success" : "bg-danger")">
                        @(item.Activo ? "Activo" : "Dado de Baja")
                    </span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <form asp-action="ToggleActivo" asp-route-id="@item.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm @(item.Activo ? "btn-outline-danger" : "btn-outline-success")">
                            @(item.Activo ? "Dar de Baja" : "Activar")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Barra de Paginación -->
<div class="d-flex justify-content-between align-items-center mt-4">
    <p class="text-muted">Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas (@ViewBag.TotalRegistros registros)</p>
    <nav>
        <ul class="pagination">
            <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual - 1)" asp-route-busqueda="@ViewBag.Busqueda">Anterior</a>
            </li>
            <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual + 1)" asp-route-busqueda="@ViewBag.Busqueda">Siguiente</a>
            </li>
        </ul>
    </nav>
</div>
